# Copy to .env for local overrides.

# Input folder scanned by scripts/index_data.py.
ALPHASEARCH_DATA_DIR=./data

# Local LanceDB directory and table name.
ALPHASEARCH_DB_DIR=./var/lancedb
ALPHASEARCH_TABLE=chunks

# Qwen model location. Use the Hugging Face id for first setup, or ./models/...
# after scripts/download_model.py has downloaded a local snapshot.
ALPHASEARCH_MODEL_PATH=Qwen/Qwen3-VL-Embedding-2B

# Qwen3-VL-Embedding-2B returns up to 2048 dimensions.
ALPHASEARCH_EMBEDDING_DIM=2048

# Tune down on low-memory machines.
ALPHASEARCH_BATCH_SIZE=4

# Used as Qwen's embedding instruction/prompt.
ALPHASEARCH_EMBEDDING_INSTRUCTION=Retrieve local files, PDF passages, and images relevant to the user's search query.

# Set to 1 during the offline demo after model files are available locally.
TRANSFORMERS_OFFLINE=0
HF_HUB_OFFLINE=0

